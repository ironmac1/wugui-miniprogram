<!-- pages/space-detail/space-detail.wxml -->
<view class="container">
  <!-- 面包屑 -->
  <view class="breadcrumb">
    <view wx:for="{{breadcrumb}}" wx:key="space_id" class="crumb-item">
      <text wx:if="{{index > 0}}" class="crumb-sep">/</text>
      <text class="crumb-name {{item.space_id === space.space_id ? 'current' : ''}}" data-id="{{item.space_id}}" bindtap="onBreadcrumbTap">{{item.name}}</text>
    </view>
  </view>

  <!-- 空间信息头 -->
  <view class="space-header">
    <view class="space-header-left">
      <view class="space-header-icon">
        <image wx:if="{{space.photo}}" src="{{space.photo}}" mode="aspectFill" class="space-header-photo" />
        <text wx:else>{{spaceIcon}}</text>
      </view>
      <view>
        <text class="space-header-name">{{space.name}}</text>
        <text class="space-header-count">{{items.length}} 件物品{{childSpaces.length > 0 ? ' · ' + childSpaces.length + ' 个子空间' : ''}}</text>
      </view>
    </view>
    <view wx:if="{{canEdit}}" class="edit-btn" bindtap="goEditSpace">编辑</view>
  </view>

  <!-- 子空间区域 -->
  <view class="child-section">
    <view class="child-header">
      <text class="child-title">子空间</text>
      <view class="add-child-btn" bindtap="goAddChildSpace">+ 添加子空间</view>
    </view>
    <view wx:if="{{childSpaces.length > 0}}" class="child-list">
      <view wx:for="{{childSpaces}}" wx:key="space_id" class="child-tile" data-id="{{item.space_id}}" bindtap="onChildSpaceTap">
        <view class="child-icon">
          <image wx:if="{{item.photo}}" src="{{item.photo}}" mode="aspectFill" class="child-photo" />
          <text wx:else>{{item.iconEmoji}}</text>
        </view>
        <view class="child-info">
          <text class="child-name text-ellipsis">{{item.name}}</text>
          <text class="child-meta">{{item.item_count || 0}}件{{item.child_count > 0 ? ' · ' + item.child_count + '个子空间' : ''}}</text>
        </view>
        <text class="child-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 操作栏 -->
  <view class="action-bar">
    <view class="sort-btn" bindtap="toggleSortPicker">
      <text>{{sortLabel}}</text>
      <text class="sort-arrow {{showSortPicker ? 'up' : ''}}">▾</text>
    </view>
    <view class="manage-btn" bindtap="toggleManage">
      <text>{{manageMode ? '完成' : '管理'}}</text>
    </view>
  </view>

  <!-- 排序选择 -->
  <view wx:if="{{showSortPicker}}" class="sort-dropdown fade-in">
    <view class="sort-option {{sortBy === 'created_desc' ? 'active' : ''}}" data-value="created_desc" bindtap="chooseSort">最近添加</view>
    <view class="sort-option {{sortBy === 'name' ? 'active' : ''}}" data-value="name" bindtap="chooseSort">按名称</view>
    <view class="sort-option {{sortBy === 'expire' ? 'active' : ''}}" data-value="expire" bindtap="chooseSort">按过期日期</view>
  </view>

  <!-- 物品列表 -->
  <view wx:if="{{items.length > 0}}" class="item-list">
    <view wx:for="{{items}}" wx:key="item_id" class="item-wrap {{manageMode && selectedIds.indexOf(item.item_id) > -1 ? 'selected' : ''}}">
      <view wx:if="{{manageMode}}" class="check-circle {{selectedIds.indexOf(item.item_id) > -1 ? 'checked' : ''}}" catchtap="toggleSelect" data-id="{{item.item_id}}">
        <text wx:if="{{selectedIds.indexOf(item.item_id) > -1}}">✓</text>
      </view>
      <view class="item-flex">
        <item-card item="{{item}}" categories="{{categories}}" advance-days="{{maxAdvanceDays}}" show-consume="{{!manageMode}}" bind:tap="onItemTap" bind:consume="onConsumeItem" />
      </view>
    </view>
  </view>

  <view wx:if="{{items.length === 0 && childSpaces.length === 0}}" class="empty-area">
    <empty-state icon="📦" title="该空间暂无物品" desc="点击下方按钮添加物品或子空间" btn-text="添加物品" bind:action="goAddItem" />
  </view>

  <view wx:if="{{items.length === 0 && childSpaces.length > 0}}" class="empty-area">
    <view class="empty-tip">该空间暂无直接物品，物品在子空间中</view>
  </view>

  <!-- 管理模式操作栏 -->
  <view wx:if="{{manageMode}}" class="manage-bar">
    <view class="manage-action" bindtap="selectAll">全选</view>
    <view class="manage-action" bindtap="batchMove">移动</view>
    <view class="manage-action text-danger" bindtap="batchDelete">删除({{selectedIds.length}})</view>
  </view>

  <view class="tabbar-height"></view>

  <!-- 添加按钮 -->
  <view wx:if="{{!manageMode}}" class="fab" bindtap="goAddItem">+</view>
</view>
