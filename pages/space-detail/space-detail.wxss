/* pages/space-detail/space-detail.wxss */

/* 面包屑 */
.breadcrumb {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  padding: 16rpx 36rpx 0;
}
.crumb-item {
  display: flex;
  align-items: center;
}
.crumb-sep {
  font-size: 24rpx;
  color: var(--color-text-3);
  margin: 0 8rpx;
}
.crumb-name {
  font-size: 24rpx;
  color: var(--color-primary);
}
.crumb-name.current {
  color: var(--color-text-2);
  font-weight: 600;
}

.space-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 36rpx 20rpx;
}
.space-header-left {
  display: flex;
  align-items: center;
}
.space-header-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}
.space-header-photo {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
}
.child-photo {
  width: 100%;
  height: 100%;
  border-radius: var(--radius);
}
.space-header-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 0.5rpx;
  display: block;
}
.space-header-count {
  font-size: 24rpx;
  color: var(--color-text-3);
}
.edit-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 12rpx 28rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: var(--radius-full);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 36rpx 16rpx;
}
.sort-btn, .manage-btn {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--color-text-2);
  padding: 10rpx 20rpx;
  background: var(--color-card);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--color-border);
}
.sort-arrow {
  margin-left: 6rpx;
  font-size: 22rpx;
  transition: transform 0.2s;
}
.sort-arrow.up { transform: rotate(180deg); }

.sort-dropdown {
  margin: 0 36rpx 16rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 8rpx 0;
  border: 1rpx solid var(--color-border);
}
.sort-option {
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--color-text-2);
}
.sort-option.active {
  color: var(--color-primary);
  font-weight: 600;
}

.item-list { padding: 0 36rpx; }
.item-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.item-wrap.selected .item-flex { width: 100%; }
.item-flex { flex: 1; }
.check-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #fff;
}
.check-circle.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.manage-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  background: var(--color-card);
  padding: 24rpx 36rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  border-top: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-sm);
  z-index: 50;
}
.manage-action {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

/* 子空间区域 */
.child-section {
  margin: 20rpx 36rpx 0;
}
.child-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.child-title {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 0.5rpx;
}
.add-child-btn {
  font-size: 25rpx;
  color: var(--color-primary);
  padding: 8rpx 20rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: var(--radius-full);
}
.child-list {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border);
  overflow: hidden;
}
.child-tile {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.child-tile:last-child { border-bottom: none; }
.child-tile:active { background: var(--color-fill); }
.child-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius);
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.child-info {
  flex: 1;
  min-width: 0;
}
.child-name {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 4rpx;
  letter-spacing: 0.5rpx;
}
.child-meta {
  font-size: 22rpx;
  color: var(--color-text-3);
}
.child-arrow {
  font-size: 32rpx;
  color: var(--color-text-3);
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 空状态 */
.empty-area {
  padding: 40rpx 0;
}
.empty-tip {
  text-align: center;
  font-size: 25rpx;
  color: var(--color-text-3);
  padding: 40rpx 0;
}
