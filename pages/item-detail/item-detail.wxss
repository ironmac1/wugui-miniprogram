/* pages/item-detail/item-detail.wxss */
.status-banner {
  display: flex;
  align-items: center;
  margin: 24rpx 36rpx 0;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-lg);
}
.status-banner.expired { background: var(--color-danger-bg); }
.status-banner.expiring_soon { background: var(--color-warning-bg); }
.banner-icon { font-size: 32rpx; margin-right: 12rpx; }
.banner-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}
.status-banner.expired .banner-text { color: var(--color-danger); }
.status-banner.expiring_soon .banner-text { color: var(--color-warning); }
.banner-action {
  font-size: 26rpx;
  color: #fff;
  background: var(--color-primary);
  padding: 10rpx 28rpx;
  border-radius: var(--radius-full);
}

.detail-card {
  display: flex;
  align-items: center;
  margin: 24rpx 36rpx 0;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  border: 1rpx solid var(--color-border);
}
.detail-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--radius);
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.detail-main { flex: 1; min-width: 0; }
.detail-name {
  font-size: 38rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: var(--color-text);
  display: block;
  margin-bottom: 12rpx;
}
.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.photo-section {
  margin: 24rpx 36rpx 0;
}
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  color: var(--color-text);
  margin-bottom: 16rpx;
}
.photo-scroll {
  white-space: nowrap;
}
.photo-item {
  display: inline-block;
  margin-right: 16rpx;
}
.photo-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius);
}

.info-section {
  margin: 24rpx 36rpx 0;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  border: 1rpx solid var(--color-border);
}
.info-list {}
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.info-row:last-child { border-bottom: none; }
.info-key {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--color-text-3);
  flex-shrink: 0;
}
.info-val {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}
.info-val.remark { line-height: 1.6; }

.meta-section {
  padding: 32rpx;
}
.meta-text {
  font-size: 22rpx;
  color: var(--color-text-3);
  display: block;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  background: var(--color-card);
  padding: 20rpx 36rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  border-top: 1rpx solid var(--color-border);
}
.bottom-action {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
}
.bottom-action:first-child {
  background: var(--color-fill);
  color: var(--color-text-2);
  margin-right: 16rpx;
}
.edit-action {
  background: var(--color-primary);
  color: #fff;
}

/* 处理状态弹窗 */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
}
.handle-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
  z-index: 201;
}
.handle-title {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  color: var(--color-text-2);
  text-align: center;
  margin-bottom: 24rpx;
}
.handle-option {
  display: flex;
  align-items: center;
  padding: 28rpx;
  font-size: 32rpx;
  color: var(--color-text);
  border-bottom: 1rpx solid var(--color-border);
}
.handle-icon { margin-right: 20rpx; font-size: 36rpx; }
.handle-cancel {
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
  color: var(--color-text-3);
  margin-top: 8rpx;
}
