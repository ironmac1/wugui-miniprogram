/* pages/search/search.wxss */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  gap: 16rpx;
}
.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-full);
  padding: 0 28rpx;
  height: 76rpx;
  box-shadow: var(--shadow-sm);
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}
.clear-btn {
  font-size: 28rpx;
  color: var(--color-text-3);
  padding: 8rpx;
}
.cancel-btn {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 600;
  white-space: nowrap;
}

.result-area { padding: 16rpx 32rpx; }
.result-count {
  font-size: 24rpx;
  color: var(--color-text-3);
  margin-bottom: 16rpx;
}

.recent-section {
  padding: 32rpx;
}
.recent-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.recent-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}
.recent-clear {
  font-size: 26rpx;
  color: var(--color-text-3);
}
.recent-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.recent-tag {
  padding: 12rpx 28rpx;
  background: var(--color-card);
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--color-text-2);
  box-shadow: var(--shadow-sm);
}

.search-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.hint-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.hint-text { font-size: 28rpx; color: var(--color-text-3); }
