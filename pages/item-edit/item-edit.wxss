/* pages/item-edit/item-edit.wxss — 修复版：高度自适应，内容完整展示 */
.form-card {
  background: var(--color-card);
  margin: 16rpx 36rpx 0;
  border-radius: var(--radius-lg);
  padding: 32rpx 28rpx;
  border: 1rpx solid var(--color-border);
  box-sizing: border-box;
}
.form-label {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  color: var(--color-text);
  margin-bottom: 18rpx;
  display: block;
}
.form-label-inline {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  color: var(--color-text);
}
.required { color: var(--color-danger); }

/* 输入框：增高，确保文字不被截断 */
.form-input {
  width: 100%;
  background: var(--color-fill);
  border-radius: var(--radius);
  padding: 28rpx 28rpx;
  font-size: 30rpx;
  line-height: 1.5;
  color: var(--color-text);
  box-sizing: border-box;
  min-height: 88rpx;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 60rpx;
}
.picker-value {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: var(--color-text);
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.picker-arrow {
  color: var(--color-text-3);
  margin-left: 8rpx;
  font-size: 36rpx;
}

/* 数量 & 品牌 行：间距加大 */
.form-row {
  display: flex;
  gap: 24rpx;
}
.form-col {
  flex: 1;
  min-width: 0;
}

.price-input-wrap {
  display: flex;
  align-items: center;
  background: var(--color-fill);
  border-radius: var(--radius);
  padding: 0 28rpx;
  min-height: 88rpx;
  box-sizing: border-box;
}
.price-prefix {
  font-size: 32rpx;
  color: var(--color-text-2);
  margin-right: 8rpx;
}
.price-input {
  background: transparent;
  padding: 28rpx 0;
  flex: 1;
  min-width: 0;
}

/* 日期行：增高 */
.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
}
.date-item {
  flex: 1;
  min-width: 0;
}
.date-value {
  font-size: 30rpx;
  color: var(--color-text);
  margin-top: 12rpx;
  line-height: 1.5;
}
.date-value.placeholder { color: var(--color-text-3); }
.clear-date {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 12rpx 20rpx;
}
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 20rpx 0;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.photo-cell {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius);
}
.photo-img {
  width: 100%;
  height: 100%;
  border-radius: var(--radius);
}
.photo-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-danger);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.photo-add {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius);
  background: var(--color-fill);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.add-icon {
  font-size: 56rpx;
  color: var(--color-text-3);
  line-height: 1;
}
.add-text {
  font-size: 22rpx;
  color: var(--color-text-3);
  margin-top: 8rpx;
}

/* 备注：增高 */
.form-textarea {
  width: 100%;
  background: var(--color-fill);
  border-radius: var(--radius);
  padding: 28rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-text);
  min-height: 160rpx;
  box-sizing: border-box;
}

/* 保存栏：固定底部，给上方留出足够空间 */
.save-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 20rpx 36rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  background: var(--color-card);
  border-top: 1rpx solid var(--color-border);
  z-index: 100;
}

/* 分类弹窗 */
.cat-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-card);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 201;
  max-height: 70vh;
  overflow-y: auto;
}

/* ============ 空间层级选择弹窗 ============ */
.space-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(43, 40, 37, 0.4);
  backdrop-filter: blur(4rpx);
  z-index: 200;
}
.space-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-card);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 201;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.space-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.space-sheet-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 1rpx;
}
.space-sheet-close {
  font-size: 30rpx;
  color: var(--color-text-3);
  padding: 8rpx;
}

/* 面包屑 */
.space-breadcrumb {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  padding: 20rpx 36rpx;
  background: var(--color-fill);
  gap: 4rpx;
}
.crumb-item-wrap {
  display: flex;
  align-items: center;
}
.crumb-sep {
  font-size: 24rpx;
  color: var(--color-text-3);
  margin: 0 4rpx;
}
.crumb-item {
  font-size: 26rpx;
  color: var(--color-text-2);
  padding: 6rpx 12rpx;
  border-radius: var(--radius-sm);
}
.crumb-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

/* 空间列表 */
.space-list {
  flex: 1;
  overflow-y: auto;
  padding: 12rpx 36rpx;
  min-height: 300rpx;
}
.space-empty {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-text-3);
  font-size: 26rpx;
}
.space-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.space-item:active {
  background: var(--color-fill);
}
.space-item-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.space-item-info {
  flex: 1;
  min-width: 0;
}
.space-item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 6rpx;
}
.space-item-meta {
  font-size: 22rpx;
  color: var(--color-text-3);
}
.space-item-next {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}
.next-text {
  font-size: 22rpx;
  color: var(--color-text-3);
}
.next-arrow {
  font-size: 32rpx;
  color: var(--color-text-3);
}

/* 确认栏 */
.space-confirm-bar {
  padding: 24rpx 36rpx;
  border-top: 1rpx solid var(--color-border);
  background: var(--color-card);
}
.space-current-path {
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}
.path-label {
  font-size: 24rpx;
  color: var(--color-text-3);
  flex-shrink: 0;
}
.path-value {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 600;
  margin-left: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
