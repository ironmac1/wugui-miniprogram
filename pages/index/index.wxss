/* pages/index/index.wxss */
.header {
  padding: 28rpx 36rpx 0;
}
.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.greeting {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  letter-spacing: 1rpx;
}
.date-text {
  font-size: 24rpx;
  color: var(--color-text-3);
  margin-top: 10rpx;
  display: block;
  letter-spacing: 0.5rpx;
}
.search-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: var(--color-card);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--color-border);
}
.search-icon { font-size: 28rpx; }

/* 数据条 — 去掉卡片感，用底线分隔 */
.stats-bar {
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx 0;
  margin-top: 28rpx;
  border: 1rpx solid var(--color-border);
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 42rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.1;
  letter-spacing: 0.5rpx;
}
.stat-label {
  font-size: 21rpx;
  color: var(--color-text-3);
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}
.stat-divider {
  width: 1rpx;
  height: 52rpx;
  background: var(--color-border);
}

/* 面板 — 用左侧色条标识，不用大块色块 */
.panel {
  margin: 20rpx 36rpx 0;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  border: 1rpx solid var(--color-border);
}
.expiring-panel { border-left: 3rpx solid var(--color-warning); }
.expired-panel { border-left: 3rpx solid var(--color-danger); }

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.panel-title-wrap {
  display: flex;
  align-items: center;
}
.panel-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}
.dot-warning { background: var(--color-warning); }
.dot-danger { background: var(--color-danger); }
.panel-title {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 0.5rpx;
}
.panel-count {
  font-size: 22rpx;
  color: var(--color-text-3);
  margin-left: 12rpx;
}
.panel-action {
  font-size: 23rpx;
  color: var(--color-primary);
}
.panel-body {
  margin-top: 20rpx;
}
.view-all {
  text-align: center;
  font-size: 25rpx;
  color: var(--color-primary);
  padding: 16rpx 0 4rpx;
  letter-spacing: 0.5rpx;
}

/* 安心提示 — 极简 */
.safe-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 20rpx 36rpx 0;
  padding: 24rpx;
  background: var(--color-success-bg);
  border-radius: var(--radius-lg);
}
.safe-icon {
  font-size: 28rpx;
  color: var(--color-success);
  font-weight: 600;
  margin-right: 10rpx;
}
.safe-text {
  font-size: 25rpx;
  color: var(--color-success);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* 空间区域 */
.section {
  margin-top: 44rpx;
  padding: 0 36rpx;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 33rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 1rpx;
}
.section-action {
  font-size: 25rpx;
  color: var(--color-primary);
}

/* 空间网格 — 一列全宽 */
.space-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.space-tile {
  width: 100%;
  box-sizing: border-box;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  border: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  transition: transform 0.15s;
}
.space-tile:active { transform: scale(0.99); }
.tile-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius);
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 0;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.tile-emoji { font-size: 36rpx; }
.tile-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 4rpx;
  letter-spacing: 0.5rpx;
}
.tile-info {
  flex: 1;
  min-width: 0;
}
.tile-count {
  font-size: 23rpx;
  color: var(--color-text-3);
}
.tile-arrow {
  font-size: 36rpx;
  color: var(--color-text-3);
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 快速添加弹窗 */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(43, 40, 37, 0.35);
  z-index: 200;
}
.quick-add-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--color-card);
  border-radius: 28rpx 28rpx 0 0;
  padding: 36rpx;
  z-index: 201;
  padding-bottom: calc(env(safe-area-inset-bottom) + 36rpx);
}
.qa-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.qa-title {
  font-size: 33rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 0.5rpx;
}
.qa-close {
  font-size: 30rpx;
  color: var(--color-text-3);
  padding: 8rpx;
}
.qa-input {
  background: var(--color-fill);
  border-radius: var(--radius);
  padding: 28rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}
.qa-space-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.qa-label {
  font-size: 27rpx;
  color: var(--color-text-2);
}
.qa-picker {
  display: flex;
  align-items: center;
  font-size: 27rpx;
  color: var(--color-text);
}
.qa-arrow {
  margin-left: 8rpx;
  color: var(--color-text-3);
  font-size: 22rpx;
}
.qa-hint {
  font-size: 23rpx;
  color: var(--color-text-3);
  margin-bottom: 28rpx;
}
