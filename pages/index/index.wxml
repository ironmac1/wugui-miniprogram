<!-- pages/index/index.wxml — 首页 -->
<view class="container">

  <!-- 顶部问候 -->
  <view class="header">
    <view class="header-top">
      <view>
        <text class="greeting">你好，{{user.nickname || '微信用户'}}</text>
        <text class="date-text">{{todayDate}}</text>
      </view>
      <view class="search-btn" bindtap="goToSearch">
        <text class="search-icon">🔍</text>
      </view>
    </view>
    <view class="stats-bar">
      <view class="stat-item">
        <text class="stat-num">{{totalItems}}</text>
        <text class="stat-label">物品总数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{spaces.length}}</text>
        <text class="stat-label">空间数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num text-warning">{{expiringItems.length + expiredItems.length}}</text>
        <text class="stat-label">待处理</text>
      </view>
    </view>
  </view>

  <!-- 临期面板 -->
  <view wx:if="{{expiringItems.length > 0}}" class="panel expiring-panel">
    <view class="panel-header" bindtap="toggleExpiring">
      <view class="panel-title-wrap">
        <view class="panel-dot dot-warning"></view>
        <text class="panel-title">即将过期</text>
        <text class="panel-count">{{expiringItems.length}}</text>
      </view>
      <text class="panel-action {{showExpiringPanel ? '' : 'collapsed'}}">查看全部 ›</text>
    </view>
    <view wx:if="{{showExpiringPanel}}" class="panel-body">
      <item-card
        wx:for="{{expiringItems}}"
        wx:key="item_id"
        item="{{item}}"
        categories="{{categories}}"
        advance-days="{{maxAdvanceDays}}"
        show-space="{{true}}"
        space-name="{{spaceNames[item.space_id]}}"
        bind:tap="onExpiringTap"
      />
      <view class="view-all" bindtap="viewAllExpiring">查看全部 ›</view>
    </view>
  </view>

  <!-- 已过期面板 -->
  <view wx:if="{{expiredItems.length > 0}}" class="panel expired-panel">
    <view class="panel-header" bindtap="toggleExpired">
      <view class="panel-title-wrap">
        <view class="panel-dot dot-danger"></view>
        <text class="panel-title">已过期</text>
        <text class="panel-count">{{expiredItems.length}}</text>
      </view>
      <text class="panel-action {{showExpiredPanel ? '' : 'collapsed'}}">查看全部 ›</text>
    </view>
    <view wx:if="{{showExpiredPanel}}" class="panel-body">
      <item-card
        wx:for="{{expiredItems}}"
        wx:key="item_id"
        item="{{item}}"
        categories="{{categories}}"
        advance-days="{{maxAdvanceDays}}"
        show-space="{{true}}"
        space-name="{{spaceNames[item.space_id]}}"
        bind:tap="onExpiredTap"
      />
      <view class="view-all" bindtap="viewAllExpired">查看全部 ›</view>
    </view>
  </view>

  <!-- 无临期过期时的安心提示 -->
  <view wx:if="{{expiringItems.length === 0 && expiredItems.length === 0}}" class="safe-banner">
    <text class="safe-icon">✓</text>
    <text class="safe-text">暂无临期物品，一切就绪</text>
  </view>

  <!-- 空间区域 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">我的空间</text>
      <text class="section-action" bindtap="goToSpaces">管理 ›</text>
    </view>

    <view wx:if="{{spaces.length > 0}}" class="space-grid">
      <view wx:for="{{spaces}}" wx:key="space_id" class="space-tile" data-id="{{item.space_id}}" bindtap="onTileTap">
        <view class="tile-icon">
          <text class="tile-emoji">{{item.iconEmoji}}</text>
        </view>
        <text class="tile-name text-ellipsis">{{item.name}}</text>
        <text class="tile-count">{{item.item_count || 0}}件</text>
      </view>
    </view>

    <empty-state wx:else icon="🏠" title="还没有空间" desc="创建你的第一个空间，开始管理家庭物品" btn-text="创建空间" bind:action="goCreateSpace" />
  </view>

  <view class="tabbar-height"></view>

  <!-- 快速添加悬浮按钮 -->
  <view class="fab" bindtap="openQuickAdd">+</view>

  <!-- 快速添加弹窗 -->
  <view wx:if="{{quickAddVisible}}" class="mask" bindtap="closeQuickAdd"></view>
  <view wx:if="{{quickAddVisible}}" class="quick-add-sheet slide-up">
    <view class="qa-header">
      <text class="qa-title">快速添加物品</text>
      <text class="qa-close" bindtap="closeQuickAdd">✕</text>
    </view>
    <input class="qa-input" placeholder="输入物品名称" value="{{quickAddName}}" bindinput="onQuickAddName" focus="{{quickAddVisible}}" confirm-type="done" bindconfirm="doQuickAdd" />
    <view class="qa-space-row">
      <text class="qa-label">归属空间</text>
      <picker mode="selector" range="{{spaces}}" range-key="name" value="{{quickAddSpaceIndex}}" bindchange="onQuickAddSpaceChange">
        <view class="qa-picker">
          <text>{{quickAddSpaceName}}</text>
          <text class="qa-arrow">▾</text>
        </view>
      </picker>
    </view>
    <view class="qa-hint">后续可在详情页完善信息</view>
    <button class="btn btn-primary btn-block btn-lg" bindtap="doQuickAdd">添加</button>
  </view>

</view>
