<!-- pages/tags/tags.wxml -->
<view class="container">
  <view class="page-header">
    <text class="page-title">标签管理</text>
    <view class="add-btn" bindtap="toggleAdd">
      <text class="add-icon">+</text>
      <text>新建</text>
    </view>
  </view>

  <!-- 新增标签输入 -->
  <view wx:if="{{showAdd}}" class="add-row fade-in">
    <input class="add-input" placeholder="输入标签名称（最多10字）" value="{{newCatName}}" bindinput="onNewCatInput" focus="{{showAdd}}" maxlength="10" confirm-type="done" bindconfirm="doAddCat" />
    <view class="add-actions">
      <view class="btn btn-ghost btn-sm" bindtap="toggleAdd">取消</view>
      <view class="btn btn-primary btn-sm" bindtap="doAddCat">添加</view>
    </view>
  </view>

  <!-- 统一标签列表 -->
  <view class="section-title">所有标签（{{allCats.length}}）</view>
  <view class="tag-list">
    <view wx:for="{{allCats}}" wx:key="category_id" class="tag-row">
      <text class="tag-emoji">{{item.icon || '🏷️'}}</text>
      <view class="tag-info">
        <text class="tag-name">{{item.name}}</text>
        <text class="tag-usage">{{usageMap[item.category_id] || 0}} 个物品</text>
      </view>
      <view class="tag-del-btn" catchtap="deleteCat" data-id="{{item.category_id}}" data-name="{{item.name}}" data-preset="{{item.is_preset}}">
        <text class="tag-del-text">删除</text>
      </view>
    </view>
  </view>

  <view wx:if="{{allCats.length === 0}}" class="empty-tags">
    <empty-state icon="🏷️" title="还没有标签" desc="点击右上角新建标签，更好地分类管理物品" />
  </view>

  <view class="hint-text">
    <text>💡 有关联物品的标签无法删除，删除后关联物品将归入"其他"分类</text>
  </view>
</view>
