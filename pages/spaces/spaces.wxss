/* pages/spaces/spaces.wxss */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 36rpx 20rpx;
}
.page-title {
  font-size: 42rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 1rpx;
}
.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.manage-toggle {
  font-size: 26rpx;
  color: var(--color-text-2);
  padding: 14rpx 28rpx;
  background: var(--color-card);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--color-border);
}
.add-btn {
  display: flex;
  align-items: center;
  background: var(--color-primary);
  color: #fff;
  padding: 14rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}
.add-btn:active { opacity: 0.85; }
.add-icon {
  font-size: 32rpx;
  margin-right: 6rpx;
  line-height: 1;
}

.space-list {
  padding: 0 36rpx;
}
.space-item-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  margin-bottom: 12rpx;
}
.space-item-wrap.selected .space-card {
  background: var(--color-primary-bg);
  border-color: var(--color-primary);
}
.space-card-flex {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}
.space-card {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  box-sizing: border-box;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  border: 1rpx solid var(--color-border);
  transition: transform 0.15s;
}
.space-card:active { transform: scale(0.99); }

.space-actions {
  flex-shrink: 0;
  margin-left: 12rpx;
}
.add-child-btn-sm {
  padding: 10rpx 20rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border-radius: var(--radius-full);
  font-size: 23rpx;
  font-weight: 500;
  white-space: nowrap;
  border: 1rpx solid var(--color-primary);
}
.add-child-btn-sm:active {
  background: var(--color-primary);
  color: #fff;
}

.space-icon-circle {
  width: 84rpx;
  height: 84rpx;
  border-radius: var(--radius);
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}
.space-emoji { font-size: 40rpx; }
.space-photo {
  width: 100%;
  height: 100%;
  border-radius: var(--radius);
}

.space-info {
  flex: 1;
  min-width: 0;
}
.space-name {
  font-size: 31rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 0.5rpx;
}
.space-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.space-count {
  font-size: 23rpx;
  color: var(--color-text-3);
}
.space-child-count {
  font-size: 23rpx;
  color: var(--color-primary);
}
.space-arrow {
  font-size: 36rpx;
  color: var(--color-text-3);
  flex-shrink: 0;
  margin-left: 12rpx;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #fff;
}
.check-circle.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}
