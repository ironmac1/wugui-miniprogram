<!-- pages/spaces/spaces.wxml -->
<view class="container">
  <view class="page-header">
    <text class="page-title">空间管理</text>
    <view class="header-actions">
      <view wx:if="{{spaces.length > 0}}" class="manage-toggle" bindtap="toggleManage">
        <text>{{manageMode ? '完成' : '管理'}}</text>
      </view>
      <view class="add-btn" bindtap="goAddSpace">
        <text class="add-icon">+</text>
        <text>新建</text>
      </view>
    </view>
  </view>

  <view wx:if="{{spaces.length > 0}}" class="space-list">
    <view wx:for="{{spaces}}" wx:key="space_id" class="space-item-wrap {{manageMode && selectedIds.indexOf(item.space_id) > -1 ? 'selected' : ''}}">
      <view wx:if="{{manageMode}}" class="check-circle {{selectedIds.indexOf(item.space_id) > -1 ? 'checked' : ''}}" catchtap="toggleSelect" data-id="{{item.space_id}}">
        <text wx:if="{{selectedIds.indexOf(item.space_id) > -1}}">✓</text>
      </view>
      <view class="space-card-flex">
        <view class="space-card" catchtap="onSpaceTap" data-id="{{item.space_id}}" bindlongpress="onSpaceLongPress" data-space="{{item}}">
          <view class="space-icon-circle">
            <image wx:if="{{item.photo}}" src="{{item.photo}}" mode="aspectFill" class="space-photo" />
            <text wx:else class="space-emoji">{{item.iconEmoji || '🏠'}}</text>
          </view>
          <view class="space-info">
            <text class="space-name text-ellipsis">{{item.name}}</text>
            <view class="space-meta">
              <text class="space-count">{{item.item_count || 0}} 件物品</text>
              <text wx:if="{{item.child_count > 0}}" class="space-child-count">{{item.child_count}} 个子空间</text>
            </view>
          </view>
          <text class="space-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 管理模式底部操作栏 -->
  <view wx:if="{{manageMode}}" class="manage-bar">
    <view class="manage-action" bindtap="toggleManage">取消</view>
    <view class="manage-action text-danger" bindtap="batchDeleteSpaces">删除({{selectedIds.length}})</view>
  </view>

  <empty-state wx:else icon="🏠" title="还没有空间" desc="创建客厅、厨房、卧室等空间，开始管理家庭物品" btn-text="创建第一个空间" bind:action="goAddSpace" />

  <view class="tabbar-height"></view>
</view>
