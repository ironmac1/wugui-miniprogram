/* pages/expired/expired.wxss */
.tab-bar {
  display: flex;
  background: var(--color-card);
  margin: 16rpx 32rpx;
  border-radius: var(--radius-full);
  padding: 6rpx;
  box-shadow: var(--shadow-sm);
}
.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: var(--color-text-2);
  border-radius: var(--radius-full);
  position: relative;
  gap: 8rpx;
}
.tab-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}
.tab-badge {
  font-size: 20rpx;
  background: var(--color-warning-bg);
  color: var(--color-warning);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-full);
}
.tab-badge.badge-danger {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}
.tab-item.active .tab-badge {
  background: rgba(255,255,255,0.25);
  color: #fff;
}

.action-bar {
  display: flex;
  justify-content: flex-end;
  padding: 0 32rpx 16rpx;
}
.manage-btn {
  font-size: 26rpx;
  color: var(--color-text-2);
  padding: 10rpx 20rpx;
  background: var(--color-card);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sm);
}

.item-area { padding: 0 32rpx; }
.item-list {}
.item-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.item-wrap.selected .item-flex { width: 100%; }
.item-flex { flex: 1; }
.check-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #fff;
}
.check-circle.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.manage-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  background: var(--color-card);
  padding: 24rpx 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.06);
  z-index: 50;
}
.manage-action {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}
