/* components/space-card/space-card.wxss */
.space-card {
  display: flex;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--color-border);
  transition: transform 0.15s;
}
.space-card:active { transform: scale(0.99); }

.space-icon-circle {
  width: 84rpx;
  height: 84rpx;
  border-radius: var(--radius);
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}
.space-emoji { font-size: 40rpx; }

.space-info {
  flex: 1;
  min-width: 0;
}
.space-name {
  font-size: 31rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 0.5rpx;
}
.space-count {
  font-size: 23rpx;
  color: var(--color-text-3);
}
.space-arrow {
  font-size: 36rpx;
  color: var(--color-text-3);
  flex-shrink: 0;
  margin-left: 12rpx;
}
