/* components/empty-state/empty-state.wxss */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96rpx 40rpx;
}
.empty-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
}
.empty-icon {
  font-size: 64rpx;
}
.empty-title {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--color-text-2);
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
}
.empty-desc {
  font-size: 25rpx;
  color: var(--color-text-3);
  text-align: center;
  line-height: 1.6;
}
.empty-btn {
  margin-top: 36rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 27rpx;
  font-weight: 500;
  padding: 20rpx 56rpx;
  border-radius: var(--radius-full);
  border: none;
  line-height: 1.2;
  letter-spacing: 1rpx;
}
.empty-btn::after { border: none; }
