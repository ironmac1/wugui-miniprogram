<!-- components/item-card/item-card.wxml -->
<view class="item-card {{item.status === 'expired' ? 'is-expired' : ''}}" bindtap="onTap" bindlongpress="onLongPress">
  <!-- 图标：有照片展示照片，否则展示分类emoji -->
  <view class="item-icon">
    <image wx:if="{{item.photos && item.photos.length > 0}}" src="{{item.photos[0].url || item.photos[0]}}" mode="aspectFill" class="item-photo" />
    <text wx:else class="icon-emoji">{{catIcon}}</text>
  </view>
  <view class="item-body">
    <!-- 第一行：物品名 + 数量 -->
    <view class="item-header">
      <text class="item-name text-ellipsis">{{item.name}}</text>
      <text wx:if="{{item.quantity > 1}}" class="qty-text">×{{item.quantity}}</text>
    </view>
    <!-- 第二行：位置 · 品牌 · 过期状态 -->
    <view class="item-meta">
      <text wx:if="{{showSpace && spaceName}}" class="meta-text">{{spaceName}}</text>
      <text wx:if="{{showSpace && spaceName && item.brand}}" class="meta-dot">·</text>
      <text wx:if="{{item.brand}}" class="meta-text">{{item.brand}}</text>
      <text wx:if="{{tag && (showSpace && spaceName || item.brand)}}" class="meta-dot">·</text>
      <text wx:if="{{tag}}" class="meta-text meta-expire {{tag.status === 'expired' ? 'expire-danger' : 'expire-warning'}}">{{tag.text}}</text>
    </view>
  </view>
  <!-- 消耗按钮 -->
  <view wx:if="{{showConsume}}" class="consume-btn" catchtap="onConsume">消耗</view>
</view>
