/* ============================================================
   物归 · 全局设计系统 v2
   设计方向：暖调极简 · 高级家居感
   灵感：Muji / Kinfolk / 日式侘寂
   核心：温润中性色为底，低饱和暖褐为魂，留白为韵
   ============================================================ */

page {
  /* —— 主色系：温润暖褐 —— */
  --color-primary: #7C6A58;          /* 暖褐 · 品牌主色，像原木家具 */
  --color-primary-dark: #6B5A48;     /* 深暖褐 · 按压态 */
  --color-primary-light: #E8E0D6;    /* 浅暖褐 · 底纹 */
  --color-primary-bg: #F2EDE6;       /* 极浅暖褐 · 卡片底纹 */

  /* —— 中性色：暖灰系（带微暖调） —— */
  --color-bg: #F5F2ED;               /* 暖麻白 · 页面背景，像亚麻布 */
  --color-card: #FFFFFF;             /* 纯白 · 卡片，干净利落 */
  --color-text: #2B2825;            /* 暖墨黑 · 主文字 */
  --color-text-2: #7A736A;          /* 暖中灰 · 次级文字 */
  --color-text-3: #ADA59B;          /* 暖浅灰 · 辅助文字 */
  --color-border: #EAE4DB;          /* 暖灰 · 分割线，极淡 */
  --color-fill: #F0EBE3;            /* 暖填充 · 输入框底 */

  /* —— 语义色：低饱和度，不刺眼 —— */
  --color-warning: #B8893E;         /* 暖琥珀 · 临期 */
  --color-warning-bg: #F8F0E3;      /* 临期背景 */
  --color-danger: #B0654A;          /* 赤陶 · 过期/删除 */
  --color-danger-bg: #F6EBE6;       /* 过期背景 */
  --color-success: #6B8268;         /* 苔藓绿 · 成功/正常 */
  --color-success-bg: #EBF0E9;      /* 成功背景 */
  --color-info: #6B7E8A;            /* 雾岩蓝 · 信息 */

  /* —— 辅助点缀色（高级双系） —— */
  --color-accent: #788C5D;          /* 墨绿 · 数据点缀 */
  --color-accent-bg: #EEF1E8;       /* 墨绿背景 */

  /* —— 圆角：偏小，更建筑感 —— */
  --radius-sm: 6rpx;
  --radius: 12rpx;
  --radius-lg: 20rpx;
  --radius-xl: 28rpx;
  --radius-full: 999rpx;

  /* —— 间距：更大留白 —— */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* —— 阴影：分层扩散，高级感 —— */
  --shadow-sm: 0 1rpx 3rpx rgba(43, 40, 37, 0.03);
  --shadow: 0 2rpx 12rpx rgba(43, 40, 37, 0.04);
  --shadow-lg: 0 6rpx 28rpx rgba(43, 40, 37, 0.07);
  /* 多重阴影：底色扩散 + 顶部1rpx高光，模拟纸张层次 */
  --shadow-premium: 0 1rpx 0 rgba(255, 255, 255, 0.6) inset, 0 4rpx 16rpx rgba(43, 40, 37, 0.05), 0 12rpx 40rpx rgba(43, 40, 37, 0.04);
  --shadow-lift: 0 1rpx 0 rgba(255, 255, 255, 0.7) inset, 0 8rpx 24rpx rgba(43, 40, 37, 0.08), 0 20rpx 56rpx rgba(43, 40, 37, 0.06);

  /* —— 字体 —— */
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", system-ui, sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
  -webkit-font-smoothing: antialiased;
}

/* —— 通用布局 —— */
.container {
  min-height: 100vh;
  background: var(--color-bg);
  box-sizing: border-box;
}

.page-padding { padding: 0 var(--space-lg); }

.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-start { display: flex; align-items: center; }
.flex-1 { flex: 1; min-width: 0; }
.flex-wrap { flex-wrap: wrap; }

/* —— 文字层级：weight 600 为主，靠 size+spacing 拉开层次 —— */
.text-title { font-size: 42rpx; font-weight: 600; color: var(--color-text); letter-spacing: 1rpx; }
.text-h2 { font-size: 34rpx; font-weight: 600; color: var(--color-text); letter-spacing: 0.5rpx; }
.text-h3 { font-size: 30rpx; font-weight: 600; color: var(--color-text); }
.text-body { font-size: 28rpx; color: var(--color-text); font-weight: 400; }
.text-body2 { font-size: 26rpx; color: var(--color-text-2); font-weight: 400; }
.text-caption { font-size: 24rpx; color: var(--color-text-3); }
.text-small { font-size: 22rpx; color: var(--color-text-3); }
.text-primary { color: var(--color-primary); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-success { color: var(--color-success); }
.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.text-ellipsis-2 { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }

/* —— 卡片：极淡边框 + 几乎无阴影 —— */
.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  border: 1rpx solid var(--color-border);
}

.card-flat {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}

/* —— 按钮：精致胶囊形 —— */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 44rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: opacity 0.2s, transform 0.15s;
  letter-spacing: 1rpx;
}
.btn::after { border: none; }
.btn:active { transform: scale(0.97); opacity: 0.85; }

.btn-primary {
  background: var(--color-primary);
  color: #fff;
}
.btn-primary:active { background: var(--color-primary-dark); }

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}

.btn-ghost {
  background: var(--color-fill);
  color: var(--color-text-2);
}

.btn-danger {
  background: var(--color-danger);
  color: #fff;
}

.btn-block { width: 100%; display: flex; }
.btn-lg { padding: 28rpx 48rpx; font-size: 30rpx; }
.btn-sm { padding: 12rpx 24rpx; font-size: 24rpx; }

/* —— 标签：低饱和，内敛 —— */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}
.tag-warning { background: var(--color-warning-bg); color: var(--color-warning); }
.tag-danger { background: var(--color-danger-bg); color: var(--color-danger); }
.tag-success { background: var(--color-success-bg); color: var(--color-success); }
.tag-primary { background: var(--color-primary-light); color: var(--color-primary); }
.tag-default { background: var(--color-fill); color: var(--color-text-2); }

/* —— 输入框：底线感，无重边框 —— */
.input {
  width: 100%;
  padding: 24rpx 28rpx;
  background: var(--color-fill);
  border-radius: var(--radius);
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}
.input-placeholder { color: var(--color-text-3); }

/* —— 分割线 —— */
.divider { height: 1rpx; background: var(--color-border); }

/* —— 安全区 —— */
.safe-bottom { padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx); }
.tabbar-height { height: calc(env(safe-area-inset-bottom) + 100rpx); }

/* —— 动效：ease-out-quart，克制 —— */
.fade-in { animation: fadeIn 0.35s cubic-bezier(0.25, 1, 0.5, 1); }
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.slide-up { animation: slideUp 0.35s cubic-bezier(0.25, 1, 0.5, 1); }
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* —— 高端化动效 —— */
/* 弹性缓动：用于按压回弹，模拟物理质感 */
.ease-elastic { transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); }

/* stagger 入场：卡片依次浮入，用 --stagger-i 控制延迟 */
.stagger-in {
  opacity: 0;
  transform: translateY(20rpx);
  animation: staggerIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  animation-delay: calc(var(--stagger-i, 0) * 60ms);
}
@keyframes staggerIn {
  to { opacity: 1; transform: translateY(0); }
}

/* 顶部下沉入场：用于头部区块 */
.drop-in {
  opacity: 0;
  transform: translateY(-12rpx);
  animation: dropIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
@keyframes dropIn {
  to { opacity: 1; transform: translateY(0); }
}

/* 数字浮现：用于统计数字 */
.num-emerge {
  opacity: 0;
  transform: scale(0.85);
  animation: numEmerge 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  animation-delay: 0.15s;
}
@keyframes numEmerge {
  to { opacity: 1; transform: scale(1); }
}

/* 骨架屏呼吸：加载态用 */
.shimmer {
  background: linear-gradient(90deg, var(--color-fill) 0%, var(--color-primary-light) 50%, var(--color-fill) 100%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 微脉冲：用于状态指示点 */
.pulse-dot {
  animation: pulseDot 2s ease-in-out infinite;
}
@keyframes pulseDot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.9); }
}

/* —— 悬浮按钮：扩散阴影 + 弹性按压（保留单FAB样式，但首页用 fab-group 容器） —— */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 140rpx);
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  box-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.2) inset, 0 6rpx 20rpx rgba(124, 106, 88, 0.3), 0 16rpx 40rpx rgba(124, 106, 88, 0.18);
  z-index: 100;
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s;
}
.fab:active {
  transform: scale(0.88);
  box-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.2) inset, 0 3rpx 10rpx rgba(124, 106, 88, 0.3);
}
/* fab-group 容器内的 fab 不再固定定位，由容器统一管理 */
.fab-group .fab {
  position: static;
  width: 104rpx;
  height: 104rpx;
}

/* —— 空状态 —— */
.empty-illustration {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}
