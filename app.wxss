/* ============================================================
   物归 · 全局样式系统
   设计理念：温暖、有序的家居工具
   主色：陶土橙 — 传达"家"的温度
   背景：暖米色 — 柔和不刺眼
   ============================================================ */

page {
  /* —— 色彩系统 —— */
  --color-primary: #C0623E;          /* 陶土橙 · 品牌主色 */
  --color-primary-dark: #A85230;     /* 深陶土 · 按压态 */
  --color-primary-light: #F4DDD0;    /* 浅陶土 · 背景/底纹 */
  --color-primary-bg: #FBF1EB;       /* 极浅陶土 · 卡片底纹 */

  --color-bg: #FAF6F0;               /* 暖米色 · 页面背景 */
  --color-card: #FFFFFF;             /* 纯白 · 卡片 */
  --color-text: #2D2A26;            /* 深炭灰 · 主文字 */
  --color-text-2: #6B655E;          /* 中灰 · 次级文字 */
  --color-text-3: #A8A29A;          /* 浅灰 · 辅助文字 */
  --color-border: #EDE7DE;          /* 暖灰 · 分割线/边框 */
  --color-fill: #F5F0E8;            /* 填充色 · 输入框底 */

  --color-warning: #E8943A;         /* 琥珀 · 临期提醒 */
  --color-warning-bg: #FDF3E4;      /* 临期背景 */
  --color-danger: #D9534F;          /* 珊瑚红 · 过期/删除 */
  --color-danger-bg: #FBEAEA;       /* 过期背景 */
  --color-success: #6B8E4E;         /* 橄榄绿 · 成功/正常 */
  --color-success-bg: #EEF4E8;      /* 成功背景 */
  --color-info: #5B89B5;            /* 雾蓝 · 信息 */

  /* —— 圆角 —— */
  --radius-sm: 8rpx;
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 999rpx;

  /* —— 间距 —— */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* —— 阴影 —— */
  --shadow-sm: 0 2rpx 12rpx rgba(45, 42, 38, 0.04);
  --shadow: 0 4rpx 24rpx rgba(45, 42, 38, 0.06);
  --shadow-lg: 0 8rpx 40rpx rgba(45, 42, 38, 0.10);

  /* —— 字体 —— */
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
  -webkit-font-smoothing: antialiased;
}

/* —— 通用布局 —— */
.container {
  min-height: 100vh;
  background: var(--color-bg);
  box-sizing: border-box;
}

.page-padding {
  padding: 0 var(--space-lg);
}

.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-start { display: flex; align-items: center; }
.flex-1 { flex: 1; min-width: 0; }
.flex-wrap { flex-wrap: wrap; }

/* —— 文字 —— */
.text-title { font-size: 40rpx; font-weight: 700; color: var(--color-text); letter-spacing: -0.5rpx; }
.text-h2 { font-size: 34rpx; font-weight: 600; color: var(--color-text); }
.text-h3 { font-size: 30rpx; font-weight: 600; color: var(--color-text); }
.text-body { font-size: 28rpx; color: var(--color-text); }
.text-body2 { font-size: 26rpx; color: var(--color-text-2); }
.text-caption { font-size: 24rpx; color: var(--color-text-3); }
.text-small { font-size: 22rpx; color: var(--color-text-3); }
.text-primary { color: var(--color-primary); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-success { color: var(--color-success); }
.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.text-ellipsis-2 { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }

/* —— 卡片 —— */
.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow);
}

.card-flat {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
}

/* —— 按钮 —— */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: opacity 0.15s, transform 0.1s;
}
.btn::after { border: none; }
.btn:active { transform: scale(0.97); }

.btn-primary {
  background: var(--color-primary);
  color: #fff;
}
.btn-primary:active { background: var(--color-primary-dark); }

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-ghost {
  background: var(--color-fill);
  color: var(--color-text-2);
}

.btn-danger {
  background: var(--color-danger);
  color: #fff;
}

.btn-block {
  width: 100%;
  display: flex;
}

.btn-lg { padding: 28rpx 48rpx; font-size: 32rpx; }
.btn-sm { padding: 12rpx 24rpx; font-size: 24rpx; }

/* —— 标签 —— */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
}
.tag-warning { background: var(--color-warning-bg); color: var(--color-warning); }
.tag-danger { background: var(--color-danger-bg); color: var(--color-danger); }
.tag-success { background: var(--color-success-bg); color: var(--color-success); }
.tag-primary { background: var(--color-primary-light); color: var(--color-primary); }
.tag-default { background: var(--color-fill); color: var(--color-text-2); }

/* —— 输入框 —— */
.input {
  width: 100%;
  padding: 24rpx 28rpx;
  background: var(--color-fill);
  border-radius: var(--radius);
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}
.input-placeholder { color: var(--color-text-3); }

/* —— 分割线 —— */
.divider {
  height: 1rpx;
  background: var(--color-border);
}

/* —— 安全区 —— */
.safe-bottom { padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx); }
.tabbar-height { height: calc(env(safe-area-inset-bottom) + 100rpx); }

/* —— 动画 —— */
.fade-in { animation: fadeIn 0.3s ease-out; }
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.slide-up { animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* —— 悬浮按钮 —— */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 140rpx);
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  box-shadow: 0 8rpx 32rpx rgba(192, 98, 62, 0.35);
  z-index: 100;
}
.fab:active { transform: scale(0.92); }

/* —— 空状态 —— */
.empty-illustration {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}
